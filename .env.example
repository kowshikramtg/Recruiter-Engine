# ============================================================
# Hiring Intelligence Engine — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# LLM Provider — used ONLY during offline pre-computation (precompute.py)
# NOT used during rank.py (no network constraint)
LLM_PROVIDER=gemini          # "gemini" or "openai"
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...

# Dataset path (absolute or relative to project root)
DATASET_PATH=./Dataset/[PUB] India_runs_data_and_ai_challenge/India_runs_data_and_ai_challenge
CANDIDATES_FILE=candidates.jsonl
SAMPLE_FILE=sample_candidates.json

# Pre-computation output paths
PRECOMPUTED_DB=./ai/pipeline/precomputed_features.db
EMBEDDINGS_CACHE=./ai/semantic_alignment/embeddings_cache.npy
ROLE_DNA_PATH=./ai/role_dna/role_dna_output.json

# Backend
DATABASE_URL=sqlite+aiosqlite:///./backend/hiring_intelligence.db
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Processing
BATCH_SIZE=1000
MAX_WORKERS=4
